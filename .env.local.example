# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Anthropic
ANTHROPIC_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Stripe Price IDs (create in Stripe dashboard → Products). Checkout silently fails if unset.
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PREMIUM=
STRIPE_PRICE_ENTERPRISE=

# Google
GOOGLE_MAPS_API_KEY=
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=

# Email
RESEND_API_KEY=

# Newsletter
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# Analytics & Monitoring
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Security
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# LiteAPI (Travel)
LITEAPI_API_KEY=
LITEAPI_SANDBOX_KEY=

# Rate Limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cron security
CRON_SECRET=

# Google Search Console (daily GSC pull cron). Service account with Webmasters.readonly scope.
# GSC_SITE_URL examples: https://humblehalal.sg/  OR  sc-domain:humblehalal.sg
GSC_SITE_URL=
GSC_SERVICE_ACCOUNT_JSON=

# Ahrefs (weekly site overview cron). Leave blank to skip.
AHREFS_API_TOKEN=
AHREFS_TARGET=humblehalal.sg
